# ===== chain =====
VECTOR_NETWORK=testnet                # testnet | mainnet — testnet until M5 gate
# per SPEC §1.1 (mainnet) / §1.2 (testnet); defaults below are TESTNET
KOIOS_URL=https://v2.koios.vector.testnet.apexfusion.org
OGMIOS_URL=https://ogmios.vector.testnet.apexfusion.org
TXSUBMIT_URL=https://submit.vector.testnet.apexfusion.org/api/submit/tx
# mainnet values:
#   KOIOS_URL=https://koios.vector.apexfusion.org/api/v1
#   OGMIOS_URL=https://ogmios.vector.mainnet.apexfusion.org
#   TXSUBMIT_URL=https://submit.vector.mainnet.apexfusion.org/api/submit/tx
# MAINNET registry (SPEC §1.3). TESTNET registry policy per @apexfusion/agent-sdk:
#   5dd5118943d5aa7329696181252a6565a27dbf2c6de92b02a6aae361 (script addr: see SDK AgentRegistry)
REGISTRY_SCRIPT_ADDR=addr1wxlp5z3fztdpsp6ha57dvx6khw82kqvgcxwu8s8rjykjcqghprf42
REGISTRY_POLICY=be1a0a2912da180757ed3cd61b56bb8eab0188c19dc3c0e3912d2c01
BASE_RPC=https://mainnet.base.org
USDC_ADDR=0x833589fCD6eDb6E08f4c7C32D4f71b54bdA02913
BAP3X_ADDR=0x9208d82f121806a34a39bb90733b4c5c54f3993e
AERO_ROUTER=0xcF77a3Ba9A5CA399B7c97c74d54e5b1Beb874E43
AERO_FACTORY=0x420DD381b31aEf6683db6B902084cB0FFECe40Da

# ===== wallets / keys (KMS in prod; raw hex only in dev — NEVER commit) =====
VECTOR_HOT_WALLET_MNEMONIC=
BASE_HOT_WALLET_PK=
PROTOCOL_TREASURY_ADDR=
REFUEL_PAYTO=

# ===== llm =====
LLM_PROVIDER=anthropic                # venice | anthropic | openai
PLANNER_MODEL=claude-fable-5
WORKER_MODEL=claude-haiku-4-5-20251001
VENICE_API_KEY=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# ===== policy (hard caps enforced in code — never relax) =====
CHECKPOINT_AP3X=50
PER_TASK_CAP_AP3X=200
DAILY_CAP_AP3X=2000
PER_SESSION_CAP_AP3X=500
ROUTER_MIN_STAKE_AP3X=500
PROTOCOL_FEE_BPS=250

# ===== bridges / x402 =====
BRIDGE_MODE=handoff                   # handoff | api | oft  (BLOCKER-1/2: APIs pending)
SKYLINE_API=
REACTOR_API=
X402_FACILITATOR_URL=https://x402.org/facilitator
X402_PROTOCOL=v2                      # live facilitator speaks x402Version 2 (BLOCKER-6); v1 = spec-pinned shape
REFUEL_LIVE=false                     # dry-run default; flip manually for the $5 live test (M3)

# Vector MCP server (Apex-Fusion/mcp-server) SSE endpoint — chain_action tools route through it
MCP_SERVER_URL=

# ===== infra =====
DATABASE_URL=postgres://apex:apex@localhost:5432/apex_conductor
# dev fallback without Docker/Postgres: DATABASE_URL=memory://
REDIS_URL=redis://localhost:6379
# dev fallback without Redis: QUEUE_DRIVER=memory
QUEUE_DRIVER=bullmq
VERIFICATION_API=

# ===== service ports =====
CONDUCTOR_PORT=4000
INDEXER_PORT=4100
REFUEL_PORT=4200
